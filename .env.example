# .env.example - Variaveis para Coolify / docker-compose
# Copie para o painel do Coolify (Environment Variables) e preencha os valores.
# Este arquivo NAO contem segredos reais - seguro para commit.

# === Database MySQL externa (ja existente no Coolify) ===
# Descobrir o host interno do seu MySQL no Coolify: ele sera algo como
# "<nome-do-resource>.coolify-network" ou o IP interno da VPS.
# Dica: se o MySQL roda em outro projeto Coolify na mesma VPS, pergunte ao
# seu admin o nome do container ou use o IP 172.x.x.x da rede coolify.
DATABASE_URL=Server=HOST_DO_MYSQL;Port=3306;Database=mvp_facial;User=root;Password=SUA_SENHA;

# === Backend ===
# JWT secret: minimo 64 caracteres. Gerar com: openssl rand -hex 48
JWT_SECRET=trocar-por-string-aleatoria-de-no-minimo-64-caracteres-aaaaaa

# AES-256-GCM key (32 bytes em base64). Criptografia dos vetores faciais (ADR-009).
# Gerar com: openssl rand -base64 32
AES_EMBEDDING_KEY=

# Chave Gemini primaria (AI Studio). Pode ficar vazio se ainda nao tem.
GEMINI_API_KEY=
# Chaves adicionais para fallback (multi-key, ADR-019). Opcionais.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Token interno compartilhado backend <-> vision-service.
# Gerar com: openssl rand -hex 32   (use o MESMO valor nos dois servicos)
INTERNAL_TOKEN=trocar-por-token-aleatorio

# === Admin /admin (ADR-022) ===
# Senha do painel administrativo. Duas formas (precedencia: hash > texto):
#   1. ADMIN_PASSWORD_HASH (SHA-256 em hex, RECOMENDADO em producao)
#      Gerar com: echo -n "sua-senha" | openssl dgst -sha256 | awk '{print $2}'
#   2. ADMIN_PASSWORD (texto plano, so para dev local)
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=admin-dev   # troque antes de qualquer demo/producao

# CORS: URL publica do frontend (para o navegador aceitar respostas do backend)
CORS_ORIGINS=https://mvp.seudominio.com

# === Frontend ===
# URL publica do backend (browser chamara direto)
NEXT_PUBLIC_API_URL=https://mvp-api.seudominio.com

# === Vision-service ===
# Dispositivo: cpu | cuda (a maioria das VPS e CPU)
DEVICE=cpu
