# Vision Service - Variaveis de ambiente
# Copiar para .env e preencher

# Token interno compartilhado com o backend C# (deve ser identico)
INTERNAL_TOKEN=trocar-este-token

# Dispositivo de processamento: cpu | cuda
DEVICE=cpu

# Pasta de cache do DeepFace (modelos baixados no primeiro uso)
DEEPFACE_HOME=./.deepface
